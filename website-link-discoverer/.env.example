# 网站链接发现器 - 配置示例
# 复制此文件为 .env 并根据需要修改配置

# ==================== 基础配置 ====================

# 起始爬取URL (默认: https://crawlee.dev)
START_URL=https://crawlee.dev

# 最大请求数量 (默认: 100)
MAX_REQUESTS=100

# 最大并发数 (默认: 1)
MAX_CONCURRENCY=1

# ==================== 超时配置 ====================

# 导航超时时间/秒 (默认: 45)
NAVIGATION_TIMEOUT_SECS=45

# 请求处理超时时间/秒 (默认: 180)
REQUEST_HANDLER_TIMEOUT_SECS=180

# 最大重试次数 (默认: 1)
MAX_REQUEST_RETRIES=1

# ==================== 输出配置 ====================

# 输出文件路径 (默认: sitemap.json)
OUTPUT_PATH=sitemap.json

# ==================== 浏览器配置 ====================

# 浏览器通道 (可选值: chrome, msedge, 留空使用默认)
# BROWSER_CHANNEL=chrome

# ==================== 资源过滤 ====================

# 屏蔽的资源类型 (用逗号分隔,默认屏蔽图片、字体、媒体)
BLOCK_RESOURCE_TYPES=image,font,media

# ==================== 敏感词过滤 ====================

# 敏感词列表 (用逗号分隔,遇到这些词的按钮不会自动点击)
# 默认包含: delete,remove,pay,submit,confirm,logout,reset,clear
SENSITIVE_WORDS=delete,remove,pay,submit,confirm,logout,reset,clear
